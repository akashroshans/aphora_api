# ── Aphasia Rehabilitation Speech Evaluation API ──
# Copy this file to .env and adjust values as needed.

# Logging
LOG_LEVEL=INFO

# WavLM model for audio embedding extraction
WAVLM_MODEL_NAME=microsoft/wavlm-base-plus

# Wav2Vec2 model for speech-to-text transcription
# Use "facebook/wav2vec2-base-960h" for lower memory usage (~360 MB)
# Use "facebook/wav2vec2-large-960h" for higher accuracy (~1.2 GB)
WAV2VEC2_MODEL_NAME=facebook/wav2vec2-large-960h
